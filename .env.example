# SECRET_KEY=change-me-in-production
# JWT_SECRET_KEY=change-this-jwt-secret
# DATABASE_URL=sqlite:///backend/proctoring.db
# CORS_ORIGINS=https://yourfrontend.vercel.app
# ADMIN_EMAIL=admin@yourschool.edu
# ADMIN_PASSWORD=SecurePassword123!
# FLASK_ENV=production
# Database Configuration
DATABASE_URL=sqlite:///proctoring_system.db

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key

# API Keys
OPENAI_API_KEY=your-openai-api-key-if-using

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
DEBUG=true

# Streamlit Cloud (if deploying)
STREAMLIT_CLIENT_LOGGER_LEVEL=info
